# Database
# SQLite (simple, no external service):
#   DATABASE_URL="file:./prisma/data/wagers.db"
# Dolt MySQL (versioned database):
#   DATABASE_URL="mysql://root@127.0.0.1:3308/wagerdb"
DATABASE_URL="file:./prisma/data/wagers.db"

# JWT Secret - generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-random-secret"

# Server
PORT=4317
NODE_ENV=development

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS="http://localhost:4317,http://localhost:5173"
